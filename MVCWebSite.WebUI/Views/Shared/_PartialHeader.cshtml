<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MVCWebSite</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Anasayfa</a>
                    </li>
                    @await Component.InvokeAsync("Kategoriler")
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Gizliik</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="ContactUs">İletişim</a>
                    </li>
                </ul>

                <form action="/Products" method="get" class="me-3">
                    <input type="search" name="q" class="form-control" placeholder="Ara.." />
                </form>

            </div>
            @if (Context.User.Identity.IsAuthenticated)
            {
                <a href="/Account/Logout" class="btn btn-danger">Oturumu Kapat</a>
                if (Context.User.IsInRole("Admin"))
                {
                    <a href="/Admin" target="_blank" class="btn btn-outline-dark ms-3">Yönetim Paneli</a>
                }
            }
            else
            {
                <a href="/Account/Login" class="btn btn-primary">Giriş Yap</a>
            }
        </div>
    </nav>
</header>