@model IEnumerable<Slider>

@{
    ViewData["Title"] = "Sliderlar";
}

<h1>Sliderlar</h1>

<p>
    <a asp-area="Admin" asp-controller="Sliders" asp-action="Create" class="btn btn-primary">Yeni Ekle</a>
</p>

<table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Başlık</th>
            <th>Açıklama</th>
            <th>Resim</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.Image</td>
                    <td>
                        <a asp-area="Admin" asp-controller="Sliders" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Düzenle</a> |
                        <a asp-area="Admin" asp-controller="Sliders" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
