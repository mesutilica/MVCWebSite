@model Slider

@{
    ViewData["Title"] = "Slider Detayı";
}

<h1>Slider Detayı</h1>

<div>
    <h4>Slider</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Id)</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Title)</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Description)</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Image)</dt>
        <dd class="col-sm-10">@Model.Image</dd>
    </dl>
</div>

<p>
    <a asp-area="Admin" asp-controller="Sliders" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Düzenle</a>
    <a asp-area="Admin" asp-controller="Sliders" asp-action="Index" class="btn btn-secondary">Geri</a>
</p>
