@model IEnumerable<Category>

@{
    ViewData["Title"] = "Kategoriler";
}

<h1>Kategoriler</h1>

<p>
    <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-primary">Yeni Ekle</a>
</p>

<table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Ad</th>
            <th>Açıklama</th>
            <th>Resim</th>
            <th>Kayıt Tarihi</th>
            <th>Durum</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Image</td>
                    <td>@item.CreateDate.ToString("g")</td>
                    <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
                    <td>
                        <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Düzenle</a> |
                        <a asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>                        
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
