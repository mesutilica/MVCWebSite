@model IEnumerable<Category>

<li class="dropdown">
    <a href="#" class="nav-link text-dark dropdown-toggle" data-bs-toggle="dropdown">Kategoriler</a>
    <ul class="dropdown-menu">
        @foreach (var category in Model)
        {
            <li>
                <a href="/Categories/Index/@category.Id" class="dropdown-item">
                    @category.Name
                </a>
            </li>
        }
        <li>
            <a href="/Products" class="dropdown-item">
                Tüm Ürünler
            </a>
        </li>
    </ul>
</li>